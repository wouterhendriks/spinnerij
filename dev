#!/bin/bash

# Friendly developer helper for Spinnerij Oosterveld PWA.
#
# Usage:
#   ./dev                   Interactive menu
#   ./dev web               Web deployen (Vercel)
#   ./dev start             Dev server starten
#   ./dev deploy            Alias voor ./dev web
#
# Tab completion: add to ~/.bash_profile:
#   eval "$(~/projects/apps/spinnerij/dev --completions)"

if [ "$1" = "--completions" ]; then
  echo 'complete -W "start web deploy --help" ./dev'
  exit 0
fi

show_help() {
  echo ""
  echo "Usage: ./dev [command]"
  echo ""
  echo "Commands:"
  echo "  start                Dev server starten (web)"
  echo "  web / deploy         Web deployen naar Vercel"
  echo ""
  echo "Without command: interactive menu"
}

# ──────────────────────────────────────────────
# start — Dev server starten
# ──────────────────────────────────────────────
do_start() {
  echo ""
  echo "Dev server starten..."
  echo "  → npx expo start --web"
  echo ""
  npx expo start --web
}

# ──────────────────────────────────────────────
# web — Web deployen (Vercel)
# ──────────────────────────────────────────────
do_web() {
  local TARGET=""

  for arg in "$@"; do
    case $arg in
      --preview)    TARGET="preview" ;;
      --production) TARGET="production" ;;
    esac
  done

  if [ -z "$TARGET" ]; then
    echo ""
    echo "Waar wil je naartoe deployen?"
    echo "  1) Production (default)"
    echo "  2) Preview"
    read -p "Kies [1-2]: " -n 1 -r
    echo
    case $REPLY in
      2) TARGET="preview" ;;
      *) TARGET="production" ;;
    esac
  fi

  # Check for uncommitted changes
  if [ -n "$(git status --porcelain)" ]; then
    echo ""
    echo "⚠️  Er zijn uncommitted changes."
    git status --short
    echo ""
    read -p "Eerst committen? [Y/n] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Nn]$ ]]; then
      git add -A
      read -p "Commit message: " -r MSG
      git commit -m "${MSG:-deploy}"
      git push
    fi
  else
    # Push any unpushed commits
    if [ -n "$(git log --oneline "@{u}..HEAD" 2>/dev/null)" ]; then
      echo ""
      echo "Unpushed commits gevonden, pushing..."
      git push
    fi
  fi

  echo ""
  echo "Building web bundle..."
  npx expo export --platform web --clear || return 1

  echo ""
  echo "Preparing Vercel output..."
  rm -rf .vercel/output
  mkdir -p .vercel/output/static
  cp -R dist/. .vercel/output/static/

  cat > .vercel/output/config.json << 'CONF'
{
  "version": 3,
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
CONF

  if [ "$TARGET" = "preview" ]; then
    echo "Deploying preview to Vercel..."
    vercel deploy --prebuilt --yes
  else
    echo ""
    echo "⚠️  Deploying to PRODUCTION."
    read -p "Weet je het zeker? [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
      echo "Afgebroken."
      return 0
    fi
    vercel deploy --prebuilt --yes --prod
  fi

  echo ""
  echo "✅ Deploy klaar!"
}

# ──────────────────────────────────────────────
# Interactive menu
# ──────────────────────────────────────────────
interactive_menu() {
  echo ""
  echo "Wat wil je doen?"
  echo ""
  echo "  1) Dev server starten"
  echo "  2) Web deployen (Vercel)"
  echo ""
  read -p "Kies [1-2]: " -n 1 -r
  echo

  case $REPLY in
    1) do_start ;;
    2) do_web ;;
    *) echo "Ongeldige keuze."; exit 1 ;;
  esac
}

# ──────────────────────────────────────────────
# Dispatch
# ──────────────────────────────────────────────
case "${1:-}" in
  start)          shift; do_start "$@" ;;
  web|deploy)     shift; do_web "$@" ;;
  --help|-h)      show_help ;;
  --completions)  exit 0 ;;
  "")             interactive_menu ;;
  *)
    echo "Onbekend commando: $1"
    echo "Run ./dev --help voor opties."
    exit 1
    ;;
esac
