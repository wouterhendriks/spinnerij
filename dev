#!/bin/bash

# Friendly developer helper for Spinnerij Oosterveld PWA.
#
# Usage:
#   ./dev                   Interactive menu
#   ./dev start             Dev server starten
#   ./dev webhare            Web deployen (WebHare)
#
# Tab completion: add to ~/.bash_profile:
#   eval "$(~/whrunkit/myserver/whdata/installedmodules/spinnerij/dev --completions)"

if [ "$1" = "--completions" ]; then
  echo 'complete -W "start webhare wh --help" ./dev'
  exit 0
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
APP_DIR="$SCRIPT_DIR/app"

show_help() {
  echo ""
  echo "Usage: ./dev [command]"
  echo ""
  echo "Commands:"
  echo "  start                Dev server starten (web)"
  echo "  webhare (wh)         Web deployen naar WebHare"
  echo ""
  echo "Flags:"
  echo "  webhare              --local (lokale API)"
  echo ""
  echo "Without command: interactive menu"
}

# ──────────────────────────────────────────────
# start — Dev server starten
# ──────────────────────────────────────────────
do_start() {
  echo ""
  echo "Dev server starten..."
  echo "  → npx expo start --web"
  echo ""
  cd "$APP_DIR" && npx expo start --web
}

# ──────────────────────────────────────────────
# webhare — Web deployen (WebHare)
# ──────────────────────────────────────────────
do_webhare() {
  local BUILD_FLAG=""
  local SERVER="https://cms.webwerf.nl/"
  local DEPLOY=true

  for arg in "$@"; do
    case $arg in
      --local) BUILD_FLAG="--local" ;;
    esac
  done

  if [ -z "$BUILD_FLAG" ]; then
    echo ""
    echo "Waar wil je naartoe deployen?"
    echo "  1) Productie — cms.webwerf.nl (default)"
    echo "  2) Lokaal — eigen WebHare server"
    read -p "Kies [1-2]: " -n 1 -r
    echo
    case $REPLY in
      2) BUILD_FLAG="--local"; DEPLOY=false ;;
      *) ;;
    esac
  fi

  # Check for uncommitted changes in the module
  local DIRTY=""
  if [ -n "$(git -C "$SCRIPT_DIR" status --porcelain)" ]; then
    DIRTY="uncommitted"
  fi
  if [ -n "$(git -C "$SCRIPT_DIR" log --oneline "@{u}..HEAD" 2>/dev/null)" ]; then
    [ -n "$DIRTY" ] && DIRTY="$DIRTY + unpushed" || DIRTY="unpushed"
  fi
  if [ -n "$DIRTY" ]; then
    echo ""
    echo "⚠️  spinnerij module heeft $DIRTY changes."
    git -C "$SCRIPT_DIR" status --short
    echo ""
  fi

  echo ""
  echo "Building..."
  "$SCRIPT_DIR/scripts/build-webhare.sh" $BUILD_FLAG || return 1

  if [ "$DEPLOY" = true ]; then
    echo ""
    echo "Deploying naar $SERVER..."
    echo "  → wh devkit:push $SERVER spinnerij"
    echo ""
    wh devkit:push "$SERVER" spinnerij
  fi
}

# ──────────────────────────────────────────────
# Interactive menu
# ──────────────────────────────────────────────
interactive_menu() {
  echo ""
  echo "Wat wil je doen?"
  echo ""
  echo "  1) Dev server starten"
  echo "  2) Web deployen (WebHare)"
  echo ""
  read -p "Kies [1-2]: " -n 1 -r
  echo

  case $REPLY in
    1) do_start ;;
    2) do_webhare ;;
    *) echo "Ongeldige keuze."; exit 1 ;;
  esac
}

# ──────────────────────────────────────────────
# Dispatch
# ──────────────────────────────────────────────
case "${1:-}" in
  start)          shift; do_start "$@" ;;
  webhare|wh)     shift; do_webhare "$@" ;;
  --help|-h)      show_help ;;
  --completions)  exit 0 ;;
  "")             interactive_menu ;;
  *)
    echo "Onbekend commando: $1"
    echo "Run ./dev --help voor opties."
    exit 1
    ;;
esac
